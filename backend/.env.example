# ==============================================================================
# AION v1 - Environment Variables Template
# Copy this file to .env and fill in your actual values
# ==============================================================================

# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# Local: mongodb://localhost:27017/aion
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/aion
MONGODB_URI=mongodb://localhost:27017/aion

# OpenAI API (REQUIRED)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# Search API (choose one - OPTIONAL)
BING_API_KEY=your-bing-search-api-key-here
# OR
SERPAPI_KEY=your-serpapi-key-here

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info

# ==============================================================================
# PRODUCTION DEPLOYMENT NOTES
# ==============================================================================
# In AWS Elastic Beanstalk:
# 1. Go to Configuration > Software > Environment Properties
# 2. Set these variables:
#    - OPENAI_API_KEY (from OpenAI dashboard)
#    - MONGODB_URI (from MongoDB Atlas)
#    - FRONTEND_URL=https://rajora.co.in
#    - NODE_ENV=production
# 3. DO NOT commit .env file to Git
# ==============================================================================
