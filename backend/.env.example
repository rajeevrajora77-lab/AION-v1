# Server Configuration
PORT=5000
NODE_ENV=development

# MongoDB Connection
# For local MongoDB:
MONGODB_URI=mongodb://localhost:27017/aion
# For MongoDB Atlas (recommended for production):
# MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/aion?retryWrites=true&w=majority

# Authentication (REQUIRED)
# Generate a secure secret: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your-secure-jwt-secret-here-min-64-chars
JWT_EXPIRES_IN=7d

# OpenAI API
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# AWS Bedrock for Open Source LLMs (Recommended)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-access-key
# Available Bedrock models: anthropic.claude-v2, meta.llama2-70b-chat-v1, mistral.mistral-7b-instruct-v0:2
BEDROCK_MODEL_ID=meta.llama2-70b-chat-v1

# Hugging Face API (Alternative for Open Source LLMs)
HUGGINGFACE_API_KEY=your-huggingface-api-key
HUGGINGFACE_MODEL=mistralai/Mistral-7B-Instruct-v0.2

# LLM Provider Selection (openai, bedrock, or huggingface)
LLM_PROVIDER=bedrock

# Search API (choose one)
BING_API_KEY=your-bing-search-api-key-here
# OR
SERPAPI_KEY=your-serpapi-key-here

# CORS Configuration
FRONTEND_URL=http://localhost:5173

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging (Optional)
LOG_LEVEL=info
DEBUG=false
