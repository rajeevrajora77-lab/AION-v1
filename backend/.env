# ⚠️ DO NOT COMMIT THIS FILE TO GIT
# This file contains sensitive secrets and should only exist locally or in AWS Elastic Beanstalk

# ==============================================================================
# CRITICAL: SET THESE IN AWS ELASTIC BEANSTALK ENVIRONMENT VARIABLES
# ==============================================================================
# OPENAI_API_KEY=<your-key-here>
# MONGODB_URI=<your-mongodb-atlas-uri-here>
# ==============================================================================

# Application Configuration
NODE_ENV=production
PORT=5000

# OpenAI Configuration
OPENAI_MODEL=gpt-4
OPENAI_MAX_TOKENS=2000

# Frontend URL (Production)
FRONTEND_URL=https://rajora.co.in

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
